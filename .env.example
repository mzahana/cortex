# ------------------------------------------------------------------------------
# LMS environment configuration — EXAMPLE FILE.
# Copy to `.env` (never commit `.env`), fill in real values. This file must only
# ever contain placeholders. `.env` is mounted read-only into containers per
# docs/deployment.md and is the ONLY source of secrets (never baked into images).
# ------------------------------------------------------------------------------

# --- Django core -----------------------------------------------------------
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=changeme-generate-a-long-random-value-and-never-commit-it
DEBUG=false
DJANGO_SETTINGS_MODULE=config.settings.prod

# ASSUMPTION (open question, docs/risks.md §3 Q3 — hostname not yet confirmed):
# using a placeholder domain. Replace with the real Cloudflare Tunnel hostname
# before deploy, and keep this in sync with the Tunnel public hostname config.
ALLOWED_HOSTS=lms.example.com
CSRF_TRUSTED_ORIGINS=https://lms.example.com

# --- Database ----------------------------------------------------------------
# Consumed directly by Django (django-environ db() parsing) AND used to derive
# the postgres container's own POSTGRES_* vars below — keep them consistent.
# NOTE: `lms` (POSTGRES_USER) is the migration/owner role. Migrations run as it.
DATABASE_URL=postgres://lms:changeme-db-password@postgres:5432/lms
POSTGRES_DB=lms
POSTGRES_USER=lms
POSTGRES_PASSWORD=changeme-db-password

# --- Application DB role (T0.5 — Postgres RLS backstop) -----------------------
# Non-superuser, NOBYPASSRLS role the migration `tenancy.0003_app_db_role`
# provisions. RLS only fires for a role subject to it, so the *runtime*
# (web/worker/beat) DB connection uses this role while migrations keep using the
# owner `lms` above. This is WIRED in docker-compose.yml: the one-off `migrate`
# service runs as owner (DATABASE_URL), and web/worker/beat override
# DATABASE_URL to APP_DATABASE_URL (lms_app). Do NOT revert the runtime services
# to the owner role — a superuser bypasses RLS and silently disables the R4
# backstop.
APP_DB_USER=lms_app
APP_DB_PASSWORD=changeme-app-db-password
APP_DATABASE_URL=postgres://lms_app:changeme-app-db-password@postgres:5432/lms

# --- Redis (cache + sessions + Celery broker/result backend, per architecture.md) --
# Distinct DB indexes to keep concerns logically separated on the one capped
# (maxmemory 256mb, allkeys-lru) redis container.
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# --- Email (Brevo, behind the EmailProvider interface) ------------------------
BREVO_API_KEY=changeme-brevo-api-key
# ASSUMPTION (open question, docs/risks.md §3 Q6 — sender identity not yet
# confirmed): placeholder sender; update once the Brevo sender domain + SPF/
# DKIM/DMARC records are set up on the real domain from Q3.
DEFAULT_FROM_EMAIL=LMS <lms@example.com>
BREVO_REPLY_TO=lms@example.com

# --- Cloudflare Tunnel ---------------------------------------------------------
# From the Cloudflare Zero Trust dashboard (Tunnels > create > token). Never
# commit a real value; cloudflared reads this at container start.
TUNNEL_TOKEN=changeme-cloudflare-tunnel-token

# --- Media storage (django-storages; filesystem now, S3-compatible later) -----
# ASSUMPTION (open question, docs/risks.md §3 Q4 — not yet confirmed): defaults
# to the mounted NAS volume for MVP. Switching MEDIA_STORAGE_BACKEND to "s3" and
# filling the S3_* vars below is a config-only change (no code change per
# architecture.md tier-2 path).
MEDIA_STORAGE_BACKEND=filesystem
MEDIA_ROOT=/app/media
MEDIA_URL=/media/
# Only required when MEDIA_STORAGE_BACKEND=s3 (e.g. Backblaze B2 / S3-compatible):
MEDIA_STORAGE_BUCKET_NAME=
MEDIA_STORAGE_ENDPOINT_URL=
MEDIA_STORAGE_ACCESS_KEY_ID=
MEDIA_STORAGE_SECRET_ACCESS_KEY=
MEDIA_STORAGE_REGION=
